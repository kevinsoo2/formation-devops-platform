{
  "name": "formation-devops-backend",
  "version": "1.0.0",
  "description": "Backend API pour la plateforme de formation DevOps - Déployé sur Render",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:push": "drizzle-kit push",
    "db:seed": "node src/db/seed.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@libsql/client": "^0.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.30.0",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.21.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
